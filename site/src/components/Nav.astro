---

---

<header
  class="sticky top-0 z-50 border-b border-border/60 backdrop-blur-md"
  style="background: rgba(12,12,14,0.85);"
>
  <nav
    class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <span
        class="font-mono text-sm font-bold bg-accent text-bg px-2 py-0.5 rounded"
        >fw</span
      >
      <span
        class="font-display font-bold text-text text-sm tracking-wide"
        >Fluid<span class="text-accent">wind</span></span
      >
    </a>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-6 text-sm text-muted">
      <a href="/docs" class="hover:text-text transition-colors"
        >Docs</a
      >
      <a href="#playground" class="hover:text-text transition-colors"
        >Playground</a
      >
      <a href="#calculator" class="hover:text-text transition-colors"
        >Calculator</a
      >
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <a
        href="https://stackblitz.com/github/koyev/fluidwind/tree/main/sandbox"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-1.5 text-sm text-muted hover:text-text transition-colors"
        aria-label="Open in StackBlitz"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="10.05" height="14" viewBox="0 0 56 78" fill="none" aria-hidden="true">
          <path d="M23.4273 48.2853C23.7931 47.5845 23.0614 46.8837 22.3298 46.8837H1.11228C0.0148224 46.8837 -0.350997 45.8326 0.380642 45.1318L40.9866 0.282084C41.7182 -0.418693 43.1815 0.282084 42.8157 1.33325L32.9386 30.0651C32.5727 30.7659 32.9386 31.4666 33.6702 31.4666H54.8877C55.9852 31.4666 56.351 32.5178 55.6194 33.2186L15.0134 77.7179C14.2818 78.4187 12.8185 77.7179 13.1843 76.6667L23.4273 48.2853Z" fill="currentColor"></path>
        </svg>
        StackBlitz
      </a>
    </div>
  </nav>
</header>
