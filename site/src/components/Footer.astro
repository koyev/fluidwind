---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-12 px-6 bg-surface/30">
  <div class="max-w-5xl mx-auto">
    <div
      class="flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <!-- Logo + tagline -->
      <div class="flex items-center gap-3">
        <span
          class="font-mono text-sm font-bold bg-accent text-bg px-2 py-0.5 rounded"
          >fw</span
        >
        <div>
          <span class="font-display font-bold text-text text-sm"
            >Fluid<span class="text-accent">wind</span></span
          >
          <p class="text-xs text-muted mt-0.5">
            Stop writing breakpoints. Write fluid.
          </p>
        </div>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-muted">
        <a
          href="https://github.com/koyev/fluidwind"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-text transition-colors flex items-center gap-1.5"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
          GitHub
        </a>
        <a
          href="https://www.npmjs.com/package/fluidwind"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-text transition-colors flex items-center gap-1.5"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331z"
            ></path>
          </svg>
          npm
        </a>
        <a
          href="/docs"
          class="hover:text-text transition-colors flex items-center gap-1.5"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-book-open-text-icon lucide-book-open-text"
            ><path d="M12 7v14"></path><path d="M16 12h2"></path><path
              d="M16 8h2"></path><path
              d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"
            ></path><path d="M6 12h2"></path><path d="M6 8h2"
            ></path></svg
          >
          Docs</a
        >
      </div>

      <!-- License + credit -->
      <div class="text-xs text-muted text-center md:text-right">
        <p>
          MIT License &copy; {currentYear}
          <a
            href="https://github.com/koyev"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-accent-hover transition-colors"
            >koyev</a
          > | Marko Jevic
        </p>
      </div>
    </div>
  </div>
</footer>
