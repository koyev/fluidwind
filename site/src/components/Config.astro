---
import { codeToHtml } from "shiki";

const defaultRangeCode = `theme: {
  fluidwind: {
    // Global default: all fw-* classes scale across this range
    defaultRange: ['375px', '1440px'],
  },
},`;

const namedRangesCode = `theme: {
  fluidwind: {
    defaultRange: ['375px', '1440px'],
    ranges: {
      // Use with: fw-text-[16px-24px]/post
      post: ['600px', '1000px'],
      // Use with: fw-text-[16px-24px]/hero
      hero: ['375px', '1920px'],
    },
  },
},`;

const remBaseCode = `// Option A: via plugin options
plugins: [require('fluidwind')({ remBase: 18 })],

// Option B: via theme
theme: {
  fluidwind: {
    remBase: 18,
  },
},

// Resolution order: plugin options → theme → default (16)`;

const inlineRangeCode = `<!-- No config needed for one-off ranges -->
<h1 class="fw-text-[28px-72px]/[480-1280]">
  Scales from 480px to 1280px viewport width
</h1>`;

const semanticScalesCode = `theme: {
  fluidwind: {
    defaultRange: ['375px', '1440px'],

    // Named font-size scale — use as fw-text-md, fw-text-xl, etc.
    fontSize: {
      sm:  ['14px', '18px'],
      md:  ['16px', '24px'],
      lg:  ['20px', '32px'],
      xl:  ['28px', '48px'],
      '2xl': ['36px', '64px'],
    },

    // Shared spacing scale — drives padding, margin, gap, and sizing utilities
    spacing: {
      xs: ['4px',  '8px'],
      sm: ['8px',  '16px'],
      md: ['16px', '32px'],
      lg: ['24px', '64px'],
    },

    // More specific scales override spacing for their utility group:
    // padding, margin, gap, sizing, borderWidth, borderRadius
  },
},`;

const semanticUsageCode = `<!-- font size -->
<h1 class="fw-text-xl">Scales 28px → 48px</h1>
<p  class="fw-text-md">Scales 16px → 24px</p>

<!-- spacing via shared scale -->
<section class="fw-p-lg fw-gap-sm">
  <!-- fw-p-lg  → padding  24px → 64px -->
  <!-- fw-gap-sm → gap     8px  → 16px -->
</section>

<!-- arbitrary values still work alongside named scales -->
<p class="fw-text-[15px-22px]">One-off size</p>`;

const twMergeCode = `import { extendTailwindMerge } from 'tailwind-merge'
import { withFluidwind } from 'fluidwind/tailwind-merge'

// Pass withFluidwind() to extendTailwindMerge — that's all it takes.
// fw-* classes now conflict with (and correctly override) standard Tailwind classes.
export const twMerge = extendTailwindMerge(withFluidwind())

// Examples:
// twMerge('p-4 fw-p-[1rem-2rem]')          → 'fw-p-[1rem-2rem]'
// twMerge('text-sm fw-text-[16px-32px]')   → 'fw-text-[16px-32px]'
// twMerge('fw-gap-[4px-16px] gap-8')       → 'gap-8'
// twMerge('fw-p-[4px-8px] fw-p-[8px-16px]') → 'fw-p-[8px-16px]'`;

const [hlDefaultRange, hlNamedRanges, hlInlineRange, hlRemBase, hlTwMerge, hlSemanticScales, hlSemanticUsage] =
  await Promise.all([
    codeToHtml(defaultRangeCode, {
      lang: "js",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(namedRangesCode, {
      lang: "js",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(inlineRangeCode, {
      lang: "html",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(remBaseCode, {
      lang: "js",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(twMergeCode, {
      lang: "ts",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(semanticScalesCode, {
      lang: "js",
      theme: "github-dark-dimmed",
    }),
    codeToHtml(semanticUsageCode, {
      lang: "html",
      theme: "github-dark-dimmed",
    }),
  ]);
---

<section
  id="config"
  class="py-16 md:py-24 px-4 md:px-6 border-t border-border bg-surface/30"
>
  <div class="max-w-5xl mx-auto">
    <div class="mb-10 md:mb-12">
      <p class="section-label mb-3">Configuration</p>
      <h2 class="section-heading text-3xl md:text-5xl mb-4">
        Configure Fluidwind
      </h2>
      <p class="text-muted text-lg max-w-xl">
        All configuration lives in your Tailwind config. Sensible
        defaults mean you don't need any config to get started.
      </p>
    </div>

    <div class="space-y-8">
      <!-- defaultRange -->
      <details class="card group" open>
        <summary
          class="flex items-center justify-between cursor-pointer list-none"
        >
          <div>
            <h3 class="font-display font-semibold text-text">
              defaultRange
            </h3>
            <p class="text-sm text-muted mt-0.5">
              The global viewport range for all fluid utilities.
            </p>
          </div>
          <div class="flex items-center gap-3">
            <code class="code-inline text-xs hidden sm:block"
              >Default: ['375px', '1440px']</code
            >
            <svg
              class="transition-transform group-open:rotate-180 text-muted"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </summary>
        <div
          class="mt-4 rounded-xl border border-border overflow-hidden"
        >
          <div
            class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
          >
            <span class="text-xs font-mono text-muted"
              >tailwind.config.js</span
            >
            <button
              class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
              data-copy={defaultRangeCode}
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                ></rect><path
                  d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                ></path>
              </svg>
              <span>Copy</span>
            </button>
          </div>
          <div set:html={hlDefaultRange} />
        </div>
      </details>
      <!-- ranges -->
      <details class="card group">
        <summary
          class="flex items-center justify-between cursor-pointer list-none"
        >
          <div>
            <h3 class="font-display font-semibold text-text">
              ranges
            </h3>
            <p class="text-sm text-muted mt-0.5">
              Named viewport ranges usable via the <code
                class="code-inline text-xs">/modifier</code
              > syntax.
            </p>
          </div>
          <svg
            class="transition-transform group-open:rotate-180 text-muted"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="mt-4 space-y-4">
          <div
            class="rounded-xl border border-border overflow-hidden"
          >
            <div
              class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
            >
              <span class="text-xs font-mono text-muted"
                >tailwind.config.js</span
              >
              <button
                class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
                data-copy={namedRangesCode}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect
                    x="9"
                    y="9"
                    width="13"
                    height="13"
                    rx="2"
                    ry="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  ></path>
                </svg>
                <span>Copy</span>
              </button>
            </div>
            <div set:html={hlNamedRanges} />
          </div>
          <div
            class="rounded-xl border border-border overflow-hidden"
          >
            <div
              class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
            >
              <span class="text-xs font-mono text-muted"
                >example.html</span
              >
              <button
                class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
                data-copy={inlineRangeCode}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect
                    x="9"
                    y="9"
                    width="13"
                    height="13"
                    rx="2"
                    ry="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  ></path>
                </svg>
                <span>Copy</span>
              </button>
            </div>
            <div set:html={hlInlineRange} />
          </div>
        </div>
      </details>

      <!-- remBase -->
      <details class="card group">
        <summary
          class="flex items-center justify-between cursor-pointer list-none"
        >
          <div>
            <h3 class="font-display font-semibold text-text">
              remBase
            </h3>
            <p class="text-sm text-muted mt-0.5">
              The root font size used when converting between px and
              rem.
            </p>
          </div>
          <div class="flex items-center gap-3">
            <code class="code-inline text-xs hidden sm:block"
              >Default: 16</code
            >
            <svg
              class="transition-transform group-open:rotate-180 text-muted"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </summary>
        <div
          class="mt-4 rounded-xl border border-border overflow-hidden"
        >
          <div
            class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
          >
            <span class="text-xs font-mono text-muted"
              >tailwind.config.js</span
            >
            <button
              class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
              data-copy={remBaseCode}
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                ></rect><path
                  d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                ></path>
              </svg>
              <span>Copy</span>
            </button>
          </div>
          <div set:html={hlRemBase} />
        </div>
      </details>
      <!-- semanticScales -->
      <details class="card group">
        <summary
          class="flex items-center justify-between cursor-pointer list-none"
        >
          <div>
            <h3 class="font-display font-semibold text-text">
              Semantic Scales
            </h3>
            <p class="text-sm text-muted mt-0.5">
              Define named values for <code class="code-inline text-xs">fontSize</code>,
              <code class="code-inline text-xs">spacing</code>, and more — use them as
              <code class="code-inline text-xs">fw-text-md</code> instead of
              <code class="code-inline text-xs">fw-text-[16px-24px]</code>.
            </p>
          </div>
          <svg
            class="transition-transform group-open:rotate-180 text-muted"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="mt-4 space-y-4">
          <p class="text-sm text-muted">
            Semantic scales eliminate magic numbers from your markup. Define them
            once in your Tailwind config; every matching
            <code class="code-inline text-xs">fw-*</code> utility picks them up
            automatically. Arbitrary
            <code class="code-inline text-xs">[min-max]</code> values still work
            alongside named keys — they are never replaced.
          </p>
          <div
            class="rounded-xl border border-border overflow-hidden"
          >
            <div
              class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
            >
              <span class="text-xs font-mono text-muted"
                >tailwind.config.js</span
              >
              <button
                class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
                data-copy={semanticScalesCode}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect
                    x="9"
                    y="9"
                    width="13"
                    height="13"
                    rx="2"
                    ry="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  ></path>
                </svg>
                <span>Copy</span>
              </button>
            </div>
            <div set:html={hlSemanticScales} />
          </div>
          <div
            class="rounded-xl border border-border overflow-hidden"
          >
            <div
              class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
            >
              <span class="text-xs font-mono text-muted">example.html</span>
              <button
                class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
                data-copy={semanticUsageCode}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect
                    x="9"
                    y="9"
                    width="13"
                    height="13"
                    rx="2"
                    ry="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  ></path>
                </svg>
                <span>Copy</span>
              </button>
            </div>
            <div set:html={hlSemanticUsage} />
          </div>
        </div>
      </details>

      <!-- tailwind-merge -->
      <details class="card group">
        <summary
          class="flex items-center justify-between cursor-pointer list-none"
        >
          <div>
            <h3 class="font-display font-semibold text-text">
              tailwind-merge
            </h3>
            <p class="text-sm text-muted mt-0.5">
              First-class conflict resolution — <code
                class="code-inline text-xs">fw-*</code
              > classes correctly override standard Tailwind (and vice-versa).
            </p>
          </div>
          <div class="flex items-center gap-3">
            <code class="code-inline text-xs hidden sm:block">Optional</code>
            <svg
              class="transition-transform group-open:rotate-180 text-muted"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-4 space-y-4">
          <p class="text-sm text-muted">
            Install <code class="code-inline text-xs">tailwind-merge</code> then
            wrap your setup with <code class="code-inline text-xs"
              >withFluidwind()</code
            > from <code class="code-inline text-xs"
              >fluidwind/tailwind-merge</code
            >. All 23 <code class="code-inline text-xs">fw-*</code> utilities are
            mapped to their corresponding tailwind-merge class groups automatically.
          </p>
          <div class="rounded-xl border border-border overflow-hidden">
            <div
              class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-surface2/50"
            >
              <span class="text-xs font-mono text-muted">tw-merge.ts</span>
              <button
                class="config-block-copy text-muted hover:text-accent transition-colors flex items-center gap-1.5 text-xs font-mono"
                data-copy={twMergeCode}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect
                    x="9"
                    y="9"
                    width="13"
                    height="13"
                    rx="2"
                    ry="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  ></path>
                </svg>
                <span>Copy</span>
              </button>
            </div>
            <div set:html={hlTwMerge} />
          </div>
        </div>
      </details>
    </div>
  </div>
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>

<script>
  function copyText(str: string) {
    const ta = document.createElement("textarea");
    ta.value = str;
    ta.setAttribute("readonly", "");
    ta.style.cssText = "position:absolute;left:-9999px";
    document.body.appendChild(ta);
    ta.select();
    try {
      document.execCommand("copy");
    } catch {}
    document.body.removeChild(ta);
    navigator.clipboard?.writeText(str).catch(() => {});
  }

  document
    .querySelectorAll<HTMLButtonElement>(".config-block-copy")
    .forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation(); // prevent toggling the details element
        const text = btn.getAttribute("data-copy") ?? "";
        copyText(text);
        const label = btn.querySelector("span");
        if (label) label.textContent = "Copied";
        btn.style.color = "#22d3ee";
        setTimeout(() => {
          if (label) label.textContent = "Copy";
          btn.style.color = "";
        }, 1800);
      });
    });
</script>
