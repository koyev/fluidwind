---
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fluidwind - Fluid Responsive Design for Tailwind CSS",
  description = "Replace breakpoint-based responsive design with smooth CSS clamp()-based fluid scaling. Stop writing sm: md: lg:. Just write fluid.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Fluidwind",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any",
  description,
  url: "https://fluidwind.com",
  downloadUrl: "https://www.npmjs.com/package/fluidwind",
  softwareVersion: "1.0.0",
  license: "https://opensource.org/licenses/MIT",
  author: {
    "@type": "Person",
    name: "Koyev",
    url: "https://github.com/koyev",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="tailwind css plugin, fluid typography, responsive design, clamp css, fluid spacing, no breakpoints, fw-text, fluidwind"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Fira+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Fluidwind" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta
      property="og:image:alt"
      content="Fluidwind — fluid responsive CSS utilities for Tailwind"
    />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Fluidwind — fluid responsive CSS utilities for Tailwind"
    />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />

    <Analytics />
    <SpeedInsights />
  </head>
  <body
    class="bg-bg text-text font-sans antialiased overflow-x-hidden"
  >
    <!-- Subtle grid texture -->
    <div
      class="fixed inset-0 pointer-events-none z-0"
      style="background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px); background-size: 64px 64px;"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
